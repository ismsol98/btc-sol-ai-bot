# ============================================
# CRYPTO SIGNAL BOT - Environment Variables
# ============================================
# SALIN FILE INI MENJADI .env DAN ISI SEMUA VALUE

# ---- TELEGRAM BOT ----
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff1234567890

# Chat ID kamu (kirim pesan ke bot, lalu cek log untuk mendapatkan chat ID)
# Bisa diisi nanti setelah bot pertama kali dijalankan
TELEGRAM_CHAT_ID=

# ---- TWELVE DATA API ----
# Daftar di https://twelvedata.com dan dapatkan API key (ada free tier)
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# ---- OPENROUTER API ----
# Daftar di https://openrouter.ai dan dapatkan API key
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ---- KONFIGURASI BOT ----
# Interval scan dalam milidetik (default: 60000 = 1 menit)
# Note: Free tier Twelve Data limit 8 req/menit, jangan terlalu cepat
SCAN_INTERVAL_MS=60000

# Mode: production atau development
NODE_ENV=production
